# Firebase Configuration (obligatorio para auth)
# Crear un proyecto en https://console.firebase.google.com
# Luego en Project settings > General > Your apps > Web app, copiar estos valores
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# Google Picker API (obligatorio para seleccionar carpeta root)
# 1. Ir a https://console.cloud.google.com/apis/credentials
# 2. Crear o usar un proyecto existente
# 3. Habilitar "Google Picker API" desde Biblioteca de APIs
# 4. En Credenciales, crear una API Key (restringir a HTTP referrers si es posible)
# 5. Crear un OAuth 2.0 Client ID tipo "Web application"
#    - Authorized JavaScript origins: http://localhost:5173
#    - (En prod: agregar la URL de produccion)
# 6. Copiar API Key y Client ID aqui
VITE_GOOGLE_API_KEY=your-google-api-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
